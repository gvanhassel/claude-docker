# Kopieer dit bestand naar .env en vul de waarden in
# cp .env.example .env

# === VERPLICHT ===
ANTHROPIC_API_KEY=sk-ant-...

# === SSH toegang ===
# Optie 1: wachtwoord
SSH_PASSWORD=verander_dit_wachtwoord

# Optie 2: SSH publieke sleutel (aanbevolen, plak hier je ~/.ssh/id_rsa.pub of id_ed25519.pub)
SSH_PUBLIC_KEY=

# === Git identiteit ===
GIT_USER_NAME=Gerard Maarten
GIT_USER_EMAIL=jouw@email.nl

# === Tailscale (optioneel — laat leeg om te skippen) ===
# Haal een auth key op via https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=
TAILSCALE_HOSTNAME=claude-docker
